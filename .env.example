# MongoDB connection string

# Default: mongodb://127.0.0.1:27017/deeplocal

# Format: mongodb://user:password@host:port/database

MONGODB="mongodb://127.0.0.1:27017/deeplocal"

# Refresh token expiration time in seconds

# Default: 2592000 (30 days)

REFRESH_EXPIRES_IN=2592000

# Access token expiration time in seconds

# Default: 300 (5 minutes)

ACCESS_EXPIRES_IN=300

# Secret used to sign JWT tokens

# Default: random value generated at startup if not defined

SECRET="cat"

# Port where the HTTP server will run

# Default: 3000

PORT=3000

# Allowed origin for CORS requests

# Example: http://localhost:5173

# If empty or not defined, CORS is disabled

ORIGIN=""

# Supabase project URL

# Example: https://your-project-id.supabase.co

SUPABASE_URL=""

# Supabase secret key used by the backend

# Starts with: sb_secret_

# This key has full access to the project (bypasses RLS)

# Never expose this value to the frontend

SUPABASE_SERVICE_ROLE_KEY=""

# Supabase storage bucket used to store link icons

# Default: icons

ICON_BUCKET="icons"
